# OzodFlow Yordamchi konfiguratsiyasi
# Faylni .env nomi bilan nusxalang va qiymatlarni to'ldiring.
# Hech qachon real token/API keylarni GitHub'ga push qilmang.

# Asosiy master bot tokeni.
# BotFather -> /newbot orqali olinadi.
MASTER_TOKEN=8883531040:AAEYrBOr7zv2ilVog9KFbqmucYOKJiqCIDw

# Konkurs bot tokeni.
# Agar bo'sh qoldirilsa, konkurs bot ishga tushmaydi, asosiy bot ishlayveradi.
KONKURS_TOKEN=8672277904:AAG1tBnP4D8c3D3wxika9bYUjo2f5kwGCQM

# Konkurs adminlari Telegram user ID ro'yxati.
# Bir nechta admin bo'lsa vergul bilan yozing.
# Masalan: KONKURS_ADMIN_IDS=111111111,222222222
KONKURS_ADMIN_IDS=7903688837

# Eslatma:
# Gemini API keylar .env ichida global saqlanmaydi.
# Har bir yaratilgan user bot uchun admin paneldan kiritiladi:
# AI sozlamalar -> Gemini API key
# AI sozlamalar -> Zaxira Gemini keylar
